# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# playwright (검증용 도구 — 산출물은 커밋하지 않음, 이슈 #209)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo

/docs

.vscode


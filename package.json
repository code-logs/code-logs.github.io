{
  "name": "code-logs",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "docs:clean": "rm -rf ./docs ./out",
    "docs": "pnpm run docs:clean && pnpm run build && mv ./out ./docs && touch ./docs/.nojekyll && pnpm run sitemap",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky",
    "sitemap": "ts-node bin/generate-sitemap.ts",
    "licenses": "license-checker-rseidelsohn --production --json --limitAttributes licenses,repository --out ./public/licenses.json"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "highlight.js": "^11.11.1",
    "next": "^15.5.18",
    "normalize.css": "^8.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sass": "^1.83.0"
  },
  "devDependencies": {
    "@types/marked": "^4.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.18",
    "husky": "^9.1.7",
    "license-checker-rseidelsohn": "^4.4.2",
    "marked": "^4.3.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.0",
      "flatted": ">=3.4.2",
      "immutable": ">=4.3.8",
      "yaml": ">=1.10.3",
      "js-yaml": ">=4.1.1",
      "minimatch": ">=3.1.3",
      "json5": ">=1.0.2",
      "word-wrap": ">=1.2.4",
      "braces": ">=3.0.3",
      "micromatch": ">=4.0.8",
      "cross-spawn": ">=7.0.5",
      "nanoid": ">=3.3.8",
      "postcss": ">=8.4.31",
      "semver": ">=7.5.2",
      "picomatch": ">=2.3.2"
    }
  }
}

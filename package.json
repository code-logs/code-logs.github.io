{
  "name": "code-logs",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "docs:clean": "rm -rf ./docs ./out",
    "docs": "pnpm run docs:clean && pnpm run build && mv ./out ./docs && touch ./docs/.nojekyll && pnpm run sitemap",
    "start": "next start",
    "lint": "eslint .",
    "prepare": "husky",
    "sitemap": "ts-node bin/generate-sitemap.ts",
    "licenses": "license-checker-rseidelsohn --production --json --limitAttributes licenses,repository --out ./public/licenses.json"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.14.0",
    "next": "^15.5.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/marked": "^4.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "husky": "^9.1.7",
    "license-checker-rseidelsohn": "^4.4.2",
    "marked": "^4.3.0",
    "postcss": "^8.5.14",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
